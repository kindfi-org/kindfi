# Resend (Email notifications)
# Get your API key at https://resend.com
RESEND_SMTP_API_KEY="re_xxxxxxxx"
# Optional: Customize sender (default: notifications@kindfi.org / KindFi)
RESEND_FROM_EMAIL="notifications@kindfi.org"
RESEND_FROM_NAME="KindFi"

# Smart Account creation during passkey registration (disabled by default)
# Set to "true" when on-chain smart wallet deployment is ready for all users
NEXT_PUBLIC_ENABLE_SMART_ACCOUNT_CREATION="false"
