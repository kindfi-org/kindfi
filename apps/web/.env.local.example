# Required: Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Required: NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Required: App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: canonical public URL for share links, SEO, and sitemaps (defaults to https://www.kindfi.org)
# NEXT_PUBLIC_SITE_URL=https://www.kindfi.org
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development

# Required: Stellar Network Configuration
STELLAR_NETWORK_URL=https://horizon-futurenet.stellar.org
NETWORK_PASSPHRASE=Test SDF Future Network ; October 2022
FACTORY_CONTRACT_ID=CCZWIOWKT4WGJQHWZFF7ARCQJFVWRXPOKG4WGY6DOZ72OHZEMKXAEGRO
CONTROLLER_CONTRACT_ID=CCZWIOWKT4WGJQHWZFF7ARCQJFVWRXPOKG4WGY6DOZ72OHZEMKXAEGRO
ACCOUNT_SECP256R1_CONTRACT_WASM=23d8e1fbdb0bb903815feb7d07b675db98b5376feedab056aab61910d41e80c1
RPC_URL=https://rpc-futurenet.stellar.org
HORIZON_URL=https://horizon-futurenet.stellar.org
STELLAR_FUNDING_SECRET_KEY=your-stellar-funding-secret-key-here

# Required: KYC API Configuration
NEXT_PUBLIC_KYC_API_BASE_URL=http://localhost:3001

# Required: Etherfuse Configuration (for fiat on/off-ramps)
# ETHERFUSE_API_KEY — from sandbox dashboard → Account → Manage Accounts
ETHERFUSE_API_KEY=your-etherfuse-api-key-here
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
# Optional: auto-resolved from GET /ramp/me when omitted (uses your org id)
ETHERFUSE_CUSTOMER_ID=your-etherfuse-customer-id-here
# Optional: auto-resolved from GET /ramp/bank-accounts when omitted
# ETHERFUSE_BANK_ACCOUNT_ID=your-etherfuse-bank-account-id-here
# Optional: auto-registered via POST /ramp/wallet when omitted
# ETHERFUSE_CRYPTO_WALLET_ID=your-etherfuse-crypto-wallet-id-here

# Optional: Redis Configuration (for rate limiting via @upstash/redis REST API)
# Vercel Upstash/KV integration sets KV_REST_API_* automatically; UPSTASH_* also work.
UPSTASH_REDIS_REST_URL=your-redis-rest-url-here
UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token-here
KV_REST_API_URL=your-redis-rest-url-here
KV_REST_API_TOKEN=your-redis-rest-token-here
# REDIS_URL / KV_URL are rediss:// TCP URLs from Vercel — not used by @upstash/redis

# Optional: Email Configuration (Resend)
RESEND_SMTP_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=notifications@kindfi.org
RESEND_FROM_NAME=KindFi

# Optional: Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-ga-measurement-id-here

# Trustless Work — network is ONLY controlled by this variable (not NODE_ENV / Vercel prod).
# Use development or testnet for testnet escrows (default). Set mainnet only when you are ready.
NEXT_PUBLIC_TRUSTLESS_WORK_NETWORK=development
# Server-only — proxied via /api/trustless-work so the key never reaches the browser.
TRUSTLESS_WORK_API_KEY=your-trustless-work-api-key-here
# Optional USDC trustline overrides (defaults follow NEXT_PUBLIC_TRUSTLESS_WORK_NETWORK):
# NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=
# NEXT_PUBLIC_MAINNET_USDC_CONTRACT_ADDRESS=
# MAINNET_PUBLIC_USDC_ISSUER=
# NEXT_PUBLIC_TESTNET_USDC_CONTRACT_ADDRESS=
# Legacy URL override — only used when NEXT_PUBLIC_TRUSTLESS_WORK_NETWORK is unset:
# TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com

# Optional: Passkey Configuration
REDIS_URL=your-redis-url-here
RP_ID=["localhost"]
RP_NAME=["App"]
EXPECTED_ORIGIN=["http://localhost:3000"]
CHALLENGE_TTL_SECONDS=60

# Optional: VAPID Configuration (for push notifications)
VAPID_EMAIL=your-vapid-email-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Optional: Indexer Configuration
CHAIN_ID=your-chain-id-here
ENDPOINT=your-endpoint-here

# Optional: Deployment Configuration
VERCEL_URL=your-vercel-url-here
PORT=3000
ALLOWED_ORIGINS=*
